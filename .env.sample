LLM_REQUEST_TIMEOUT_SECONDS=300000
LLM_CONNECT_TIMEOUT_SECONDS=60
LLM_HTTP_MAX_ATTEMPTS=20
LLM_HTTP_RETRY_BACKOFF_S=1.0

# MinIO credentials used by the local Docker stack.
# These MUST match what the API + worker use as S3 credentials.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Explicitly set S3 credentials 
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# llama.cpp server model launch settings
LLM_MODEL_PATH=/models/Qwen2.5-Coder-7B-Instruct-Q4_K_M.gguf
LLM_THREADS=8

# make this value 0 for no cap
LLM_CTX_SIZE=4096
LLM_CHAT_TEMPLATE=qwen2
LLM_N_GPU_LAYERS=999

LLAMA_CPP_SERVER_IMAGE=ghcr.io/ggml-org/llama.cpp:server-b8475
LLAMA_CPP_SERVER_CUDA_IMAGE=ghcr.io/ggml-org/llama.cpp:server-cuda-b8475
