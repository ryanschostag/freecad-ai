LLM_REQUEST_TIMEOUT_SECONDS=300000
LLM_CONNECT_TIMEOUT_SECONDS=60
LLM_HTTP_MAX_ATTEMPTS=20
LLM_HTTP_RETRY_BACKOFF_S=1.0

# MinIO credentials used by the local Docker stack.
# These MUST match what the API + worker use as S3 credentials.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Explicitly set S3 credentials 
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
